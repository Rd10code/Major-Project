<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crreating new listing</title>
</head>
<body>
    <h3>Create a new Listing :</h3>
    <form method="post" action="/listings">
        <input name="listing[title]" placeholder="Enter title" type="text">
        <br><br>
        <textarea name="listing[description]" placeholder="Enter title="></textarea>
        <br><br>
        <input name="listing[price]" placeholder="Enter Price" type="number">
        <br><br>
        <input name="listing[image]" placeholder="Enter Image URL" type="text">
        <br><br>
        <input name="listing[location]" placeholder="Enter location " type="text">
        <br><br>
        <input name="listing[country]" placeholder="Enter Country " type="text">
        <br> <br>
        <button>Add</button>
    </form>
</body>
</html>